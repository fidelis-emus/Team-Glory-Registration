  "firestore": {
    "/first_timers/{id}": {
      "schema": "firstTimer",
      "description": "First timers contact list"
    },
    "/first_timer_workers/{id}": {
      "schema": "volunteer",
      "description": "First timers volunteering inside the workforce"
    },
    "/members/{id}": {
      "schema": "member",
      "description": "RCCG House of Glory Members list"
    },
    "/member_workers/{id}": {
      "schema": "volunteer",
      "description": "Members volunteering inside the workforce"
    },
    "/workers/{id}": {
      "schema": "volunteer",
      "description": "Existing workers inside the workforce"
    },
    "/training_registrations/{id}": {
