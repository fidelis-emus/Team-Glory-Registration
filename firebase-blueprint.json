{
  "entities": {
    "volunteer": {
      "title": "Volunteer Record",
      "description": "Volunteer registration details for TEAM GLORY RCCG House of Glory, YP2",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "memberId": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "email": { "type": "string" },
        "gender": { "type": "string" },
        "dateOfBirth": { "type": "string" },
        "maritalStatus": { "type": "string" },
        "address": { "type": "string" },
        "churchDuration": { "type": "string" },
        "churchMember": { "type": "boolean" },
        "houseFellowshipStatus": { "type": "boolean" },
        "houseFellowshipName": { "type": "string" },
        "workersTrainingStatus": { "type": "string" },
        "class": { "type": "string" },
        "completionDate": { "type": "string" },
        "enrollNextClass": { "type": "boolean" },
        "firstUnit": { "type": "string" },
        "secondUnit": { "type": "string" },
        "flexibleUnit": { "type": "boolean" },
        "skills": { "type": "array" },
        "reasonForService": { "type": "string" },
        "sundayAvailability": { "type": "boolean" },
        "meetingsAvailability": { "type": "boolean" },
        "trainingAvailability": { "type": "boolean" },
        "programmesAvailability": { "type": "boolean" },
        "recommendationType": { "type": "string" },
        "recommendationName": { "type": "string" },
        "recommendationPhone": { "type": "string" },
        "commitmentAgreed": { "type": "boolean" },
        "assignedHodId": { "type": "string" },
        "registrationDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "phoneNumber", "email", "gender", "firstUnit", "secondUnit", "commitmentAgreed", "memberId"]
    },
    "headOfDepartment": {
      "title": "Head of Department Record",
      "description": "Leader details of specific church ministry departments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" }
      },
      "required": ["fullName", "department"]
    }
  },
  "firestore": {
    "/team_glory_members/{id}": {
      "schema": "volunteer",
      "description": "Registered volunteers list"
    },
    "/heads_of_departments/{id}": {
      "schema": "headOfDepartment",
      "description": "Head of Departments register"
    }
  }
}
