rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Catch-All (Zero Trust)
    match /{document=**} {
      allow read, write: if false;
    }

    // Admin profiles
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == adminId;
    }

    // Heads of Departments collection
    match /heads_of_departments/{id} {
      allow read, write: if request.auth != null || isChurchAdmin();
    }

    // Birthday notifications logging history
    match /birthday_notifications/{id} {
      allow create, read, update, delete: if request.auth != null || isChurchAdmin();
    }

    // Segment 1: First Timers
    match /first_timers/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null || isChurchAdmin();
    }

    // Segment 2: First Timer Workers
    match /first_timer_workers/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null || isChurchAdmin();
    }

    // Segment 3: Members
    match /members/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null || isChurchAdmin();
    }

    // Segment 4: Member Workers
    match /member_workers/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null || isChurchAdmin();
    }

    // Segment 5: Workers
    match /workers/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null || isChurchAdmin();
    }

    // Segment 6: Training Registrations
    match /training_registrations/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null || isChurchAdmin();
    }

    // Segment 7: House Fellowship Registrations
    match /house_fellowship_registrations/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null || isChurchAdmin();
    }

    // Segment 8: Interest Groups
    match /interest_groups/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null || isChurchAdmin();
    }

    // Backward compatibility collection
    match /team_glory_members/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null || isChurchAdmin();
    }

    // Security Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isChurchAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "fidelisemus@gmail.com" ||
        request.auth.token.email == "admin@teamglory.com"
      );
    }
  }
}
